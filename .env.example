# Bank Nifty monthly credit spread (bank-nifty-credit-spread page).
# Strategy rules: sell futures-ATM monthly CE + buy the ~Rs100 hedge CE on the
# first trading day after monthly expiry (09:45); exit both legs at 09:20 when
# CREDIT_SPREAD_EXIT_TRADING_DAYS_BEFORE_EXPIRY trading days remain.
# Mode PAPER simulates fills at chain LTP; LIVE additionally requires
# LIVE_ORDER_ENABLED=true before any Dhan order is sent.
CREDIT_SPREAD_MONITOR_ENABLED=true
CREDIT_SPREAD_MODE=PAPER
CREDIT_SPREAD_PAPER_AUTO_APPROVE=true
CREDIT_SPREAD_LOT_SIZE=30
CREDIT_SPREAD_LOTS=1
CREDIT_SPREAD_CAPITAL_BASE=150000
CREDIT_SPREAD_ENTRY_TIME=09:45
CREDIT_SPREAD_ENTRY_WINDOW_END=14:30
CREDIT_SPREAD_EXIT_TIME=09:20
CREDIT_SPREAD_EXIT_TRADING_DAYS_BEFORE_EXPIRY=10
CREDIT_SPREAD_HEDGE_PREMIUM_TARGET=100
CREDIT_SPREAD_MIN_NET_CREDIT=500
CREDIT_SPREAD_MIN_CREDIT_WIDTH_PERCENT=22
CREDIT_SPREAD_MAX_ENTRY_VIX=24
CREDIT_SPREAD_PROFIT_TARGET_PERCENT=50
CREDIT_SPREAD_HARD_STOP_CREDIT_MULTIPLE=0
CREDIT_SPREAD_ALLOW_LATE_ENTRY=true
CREDIT_SPREAD_MIN_ENTRY_TRADING_DAYS_LEFT=12
# Comma-separated yyyy-mm-dd days to never enter on (Budget, RBI policy, etc.)
CREDIT_SPREAD_SKIP_DATES=
# Keep in sync with the official NSE holiday circular every January —
# trading-day counts (and therefore the T-10 exit date) depend on it.
NSE_HOLIDAYS=2026-01-15,2026-01-26,2026-03-03,2026-03-26,2026-03-31,2026-04-03,2026-04-14,2026-05-01,2026-05-28,2026-06-26,2026-09-14,2026-10-02,2026-10-20,2026-11-10,2026-11-24,2026-12-25
